SET NULL "NULL";
SET FEEDBACK OFF;
SET ECHO OFF;
SET HEADING OFF;
SET WRAP OFF;
SET LINESIZE 10000;
SET TAB OFF;
SET PAGES 0;
SET DEFINE OFF;
SET SERVEROUTPUT ON;

BEGIN
    FOR rec IN (
        SELECT 
            c.company_code,
            c.founder,

            (SELECT COUNT(DISTINCT lead_manager_code)
             FROM Lead_Manager lm
             WHERE lm.company_code = c.company_code) AS lead_cnt,

            (SELECT COUNT(DISTINCT senior_manager_code)
             FROM Senior_Manager sm
             WHERE sm.company_code = c.company_code) AS senior_cnt,

            (SELECT COUNT(DISTINCT manager_code)
             FROM Manager m
             WHERE m.company_code = c.company_code) AS manager_cnt,

            (SELECT COUNT(DISTINCT employee_code)
             FROM Employee e
             WHERE e.company_code = c.company_code) AS emp_cnt

        FROM Company c
        ORDER BY c.company_code
    )
    LOOP
        DBMS_OUTPUT.PUT_LINE(
            rec.company_code || ' ' ||
            rec.founder || ' ' ||
            rec.lead_cnt || ' ' ||
            rec.senior_cnt || ' ' ||
            rec.manager_cnt || ' ' ||
            rec.emp_cnt
        );
    END LOOP;
END;
/
exit;
