SET NULL "NULL";
SET FEEDBACK OFF;
SET ECHO OFF;
SET HEADING OFF;
SET WRAP OFF;
SET LINESIZE 10000;
SET TAB OFF;
SET PAGES 0;
SET DEFINE OFF;

/*
Enter your query here.
Please append a semicolon ";" at the end of the query and enter your query in a single line to avoid error.
*/
SELECT Doctor, Professor, Singer, Actor
FROM (
    SELECT 
        Name, 
        Occupation, 
        ROW_NUMBER() OVER (PARTITION BY Occupation ORDER BY Name) AS row_num
    FROM OCCUPATIONS
)
PIVOT (
    MAX(Name) 
    FOR Occupation IN (
        'Doctor' AS Doctor, 
        'Professor' AS Professor, 
        'Singer' AS Singer, 
        'Actor' AS Actor
    )
)
ORDER BY row_num;

exit;
