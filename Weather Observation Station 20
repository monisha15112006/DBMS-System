SET NULL "NULL";
SET FEEDBACK OFF;
SET ECHO OFF;
SET HEADING OFF;
SET WRAP OFF;
SET LINESIZE 10000;
SET TAB OFF;
SET PAGES 0;
SET DEFINE OFF;
SELECT ROUND(AVG(LAT_N), 4)
FROM (
    SELECT LAT_N, 
           ROW_NUMBER() OVER (ORDER BY LAT_N) AS rn_asc,
           ROW_NUMBER() OVER (ORDER BY LAT_N DESC) AS rn_desc
    FROM STATION
) 
WHERE rn_asc IN (rn_desc, rn_desc - 1, rn_desc + 1);

